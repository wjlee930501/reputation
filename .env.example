# ══════════════════════════════════════════════════════════════════
# Re:putation — 환경변수 템플릿 (Docker Compose 기준)
# cp .env.example .env 후 REPLACE_ME 항목을 실제 키로 교체
# ══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://reputation:reputation@db:5432/reputation
SYNC_DATABASE_URL=postgresql://reputation:reputation@db:5432/reputation

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic — 콘텐츠 생성 ───────────────────────────────────────
# 👉 https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REPLACE_ME
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# ── Google Cloud — Imagen 3 이미지 생성 + GCS 저장 ─────────────────
# 👉 GCP Console > IAM > 서비스 계정 키 JSON 다운로드
GCP_PROJECT_ID=REPLACE_ME
GCP_LOCATION=us-central1
GCP_STORAGE_BUCKET=reputation-images
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── OpenAI — SoV 쿼리 발송·파싱 ──────────────────────────────────
# 👉 https://platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL_QUERY=gpt-4o
OPENAI_MODEL_PARSE=gpt-4o-mini

# ── Gemini — SoV 측정 (ChatGPT + Gemini 양대 플랫폼) ──────────────
# 👉 https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-flash-latest

# ── Slack ─────────────────────────────────────────────────────────
# 👉 Slack App > Incoming Webhooks > Add New Webhook to Workspace
SLACK_WEBHOOK_URL=REPLACE_ME

# ── Report ────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=/tmp/reports

# ── App ───────────────────────────────────────────────────────────
APP_ENV=development
ADMIN_SECRET_KEY=REPLACE_ME
# Admin Next.js 로그인 비밀번호
ADMIN_LOGIN_PASSWORD=REPLACE_ME
# Admin Next.js 세션 서명용. 로그인 비밀번호와 반드시 다르게 설정.
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SESSION_SECRET=REPLACE_ME

# ── Flower ────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_ME

# ── SoV ───────────────────────────────────────────────────────────
# 테스트: 2 / 프로덕션: 10
SOV_REPEAT_COUNT=2

# ── Admin / Audit ─────────────────────────────────────────────────
# audit_log actor — AE 1명 운영 모델. 다중 운영자 도입 시 NextAuth로 전환.
ADMIN_ACTOR_NAME=AE
# Admin Next.js 콘솔의 외부 URL — Slack 알림 deep-link 등에 사용
ADMIN_BASE_URL=http://localhost:3000

# ── Site (public) ─────────────────────────────────────────────────
# /privacy, /terms, llms.txt 등 absolute URL용
SITE_BASE_URL=https://reputation.co.kr
# Site → Backend 호출용 base. Next.js 측은 NEXT_PUBLIC_API_URL로 별도 설정.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Sales Lead (개인정보보호법 컴플라이언스) ──────────────────────
# 수집일로부터 자동 파기까지 일수 (법 제21조). purge_expired_leads beat가 04:00 KST 매일 실행.
LEAD_RETENTION_DAYS=180
# 처리방침 버전 — site/app/privacy 와 동기. 변경 시 기존 동의는 무효, 재동의 필요.
LEAD_CONSENT_VERSION=v1.2026-05
# Public 폼 rate-limit. slowapi 형식: "5/minute;30/hour;100/day"
PUBLIC_LEAD_RATE_LIMIT=5/minute;30/hour;100/day
