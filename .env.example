# ══════════════════════════════════════════════════════════════════
# Re:putation — 환경변수 템플릿 (Docker Compose 기준)
# cp .env.example .env 후 REPLACE_ME 항목을 실제 키로 교체
# ══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://reputation:reputation@db:5432/reputation
SYNC_DATABASE_URL=postgresql://reputation:reputation@db:5432/reputation
# 프로덕션(Cloud Run)에서는 위 URL 대신 아래 4개로 /cloudsql/<conn> unix socket
# URL을 자동 조립한다 (config.py). DB_PASSWORD는 Secret Manager 권장.
DB_NAME=reputation
DB_USER=reputation
DB_PASSWORD=
# 예: my-project:us-central1:reputation-db (deploy.sh migrate가 필요로 한다)
CLOUD_SQL_CONNECTION_NAME=

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic — 콘텐츠 생성 ───────────────────────────────────────
# 👉 https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REPLACE_ME
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# ── Jina Reader — 프로파일 자동 채우기(네이버 플레이스 등 봇 차단 사이트 우회 읽기) ──
# 선택값: 비워두면 무인증 free tier로 동작(분당 요청 제한). 키가 있으면 상향.
# 👉 https://jina.ai/reader (API Key 발급)
JINA_API_KEY=

# ── 콘텐츠 대표 이미지 생성기 ────────────────────────────────────
# openai = gpt-image-2 (기본, editorial 일러스트), imagen = Vertex AI Imagen 3 폴백
IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x864
OPENAI_IMAGE_QUALITY=high

# ── Google Cloud — Imagen 3 이미지 생성(폴백) + GCS 저장 ───────────
# 👉 GCP Console > IAM > 서비스 계정 키 JSON 다운로드
GCP_PROJECT_ID=REPLACE_ME
GCP_LOCATION=us-central1
# 프로덕션 버킷명은 전역 유일 제약 때문에 'reputation-images'가 아니라
# 'reputation-images-<GCP_PROJECT_ID>' 규칙을 따른다 (terraform storage.tf / setup-gcp.sh).
# 로컬/개발은 아래 기본값으로 충분(실제 GCS 미사용).
GCP_STORAGE_BUCKET=reputation-images
CERTIFICATE_MANAGER_AUTO_PROVISION=false
CERTIFICATE_MANAGER_LOCATION=global
CERTIFICATE_MAP_NAME=reputation-certmap
# GCS 미구성 개발/프리뷰 환경에서 업로드 자산을 보관할 로컬 경로.
# docker-compose에서는 private_asset_uploads 볼륨으로 영속화됨.
ASSET_LOCAL_UPLOAD_DIR=/tmp/private_asset_uploads
# 미설정(빈 값)으로 두면 docker-compose의 ${VAR:-/dev/null} fallback이 동작.
# 실제 이미지 생성을 사용하려면 절대 경로의 service-account.json 지정.
GOOGLE_APPLICATION_CREDENTIALS=

# ── OpenAI — SoV 쿼리 발송·파싱 ──────────────────────────────────
# 👉 https://platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL_QUERY=gpt-4o
OPENAI_MODEL_PARSE=gpt-4o-mini

# ── Gemini — SoV 측정 (ChatGPT + Gemini 양대 플랫폼) ──────────────
# 👉 https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-flash-latest

# ── Cost Guard ────────────────────────────────────────────────────
# 전역 비용 가드레일 + 킬스위치. 콘텐츠/이미지/SoV 호출이 병원 수에 비례해 무제한
# 확장되는 것을 카테고리별 일/월 상한과 킬스위치로 차단한다.
COST_GUARD_ENABLED=true
# 월간 상한 (병원50 × 16편 × 재시도 여유 ≈ 2500)
COST_GUARD_MONTHLY_CONTENT_CALLS=2500
COST_GUARD_MONTHLY_IMAGE_CALLS=2500
# SoV 월간 측정 예산 (spec 단위)
COST_GUARD_MONTHLY_SOV_QUERIES=20000
# 일일 상한 = 월간의 1/10 수준 (하루 폭주 차단용)
COST_GUARD_DAILY_CONTENT_CALLS=250
COST_GUARD_DAILY_IMAGE_CALLS=250
COST_GUARD_DAILY_SOV_QUERIES=2000

# ── Slack ─────────────────────────────────────────────────────────
# 👉 Slack App > Incoming Webhooks > Add New Webhook to Workspace
SLACK_WEBHOOK_URL=REPLACE_ME
# webhook SSRF 방어 — 허용 호스트(쉼표 구분). 기본은 Slack 공식 호스트만.
SLACK_WEBHOOK_ALLOWED_HOSTS=hooks.slack.com

# ── Report ────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=/tmp/reports
# GCS 버킷 (월간/V0 PDF 영구 보관). 미지정 시 로컬 디렉토리만 사용.
# 프로덕션 규칙: 'reputation-reports-<GCP_PROJECT_ID>' (전역 유일 제약).
GCS_REPORTS_BUCKET=reputation-reports

# ── App ───────────────────────────────────────────────────────────
APP_ENV=development
ADMIN_SECRET_KEY=REPLACE_ME
# Admin Next.js 세션 서명용. Admin API 키와 반드시 다르게 설정.
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SESSION_SECRET=REPLACE_ME

# ── Flower ────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_ME

# ── SoV ───────────────────────────────────────────────────────────
# 테스트: 2 / 프로덕션: 10
SOV_REPEAT_COUNT=2
# 주간 모니터링 측정 반복 횟수 (프로덕션 기본: 5)
SOV_REPEAT_COUNT_WEEKLY=5
# 주간 측정 HIGH 우선순위 쿼리 상한 — 초과분은 잘라내고 ops 알림 (비용 가드)
SOV_HIGH_PRIORITY_CAP=30

# ── Admin / Audit ─────────────────────────────────────────────────
# audit_log actor — AE 1명 운영 모델. 다중 운영자 도입 시 NextAuth로 전환.
ADMIN_ACTOR_NAME=AE
# Admin Next.js 콘솔의 외부 URL — Slack 알림 deep-link 등에 사용
ADMIN_BASE_URL=http://localhost:3000

# ── Site (public) ─────────────────────────────────────────────────
# /privacy, /terms, llms.txt 등 absolute URL용
SITE_BASE_URL=https://reputation.co.kr
# Site → Backend 호출용 base. Next.js 측은 NEXT_PUBLIC_API_URL로 별도 설정.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# X-Forwarded-For 신뢰 프록시 CIDR (쉼표 구분). 프로덕션은 LB/GFE 범위 필수 —
# 0.0.0.0/0은 부팅 거부. 예: 130.211.0.0/22,35.191.0.0/16
TRUSTED_PROXY_IPS=127.0.0.1,::1
# Public 콘텐츠 허브 읽기 API rate-limit (slowapi 형식)
PUBLIC_SITE_RATE_LIMIT=300/minute;6000/hour

# ── Domain ────────────────────────────────────────────────────────
# 병원 커스텀 도메인 CNAME 검증 대상
CNAME_TARGET=aeo.motionlabs.io

# ── Observability ─────────────────────────────────────────────────
LOG_LEVEL=INFO
# 프로덕션(Cloud Logging)은 true, 로컬 가독성은 false 권장
LOG_JSON=true
# Sentry 에러 트래킹 (선택). 빈 값이면 비활성.
SENTRY_DSN=

# ── Sales Lead (개인정보보호법 컴플라이언스) ──────────────────────
# 수집일로부터 자동 파기까지 일수 (법 제21조). purge_expired_leads beat가 04:00 KST 매일 실행.
LEAD_RETENTION_DAYS=180
# 처리방침 버전 — site/app/privacy 와 동기. 변경 시 기존 동의는 무효, 재동의 필요.
LEAD_CONSENT_VERSION=v1.2026-05
# Public 폼 rate-limit. slowapi 형식: "5/minute;30/hour;100/day"
PUBLIC_LEAD_RATE_LIMIT=5/minute;30/hour;100/day

# ── Site revalidate webhook (콘텐츠 발행 시 sitemap·hub·llms.txt 즉시 갱신) ────
# 빈 값으로 두면 호출 생략 (개발 환경 OK).
SITE_REVALIDATE_URL=http://localhost:3000/api/revalidate
SITE_REVALIDATE_SECRET=

# ── Site BFF 방문자 IP 전달 (CDX-M1) ──────────────────────────────
# site /api/leads BFF와 공유. 설정 시 X-BFF-Auth + X-Visitor-IP 헤더로 전달된
# 실제 방문자 IP를 backend가 채택. 빈 값이면 비활성 (개발 환경 OK).
SITE_BFF_SECRET=

# ── ChatGPT 측정 모드 ─────────────────────────────────────────────
# False: chat.completions = OpenAI 모델 recall (실제 ChatGPT Search 답변과 다름)
# True:  Responses API + web_search tool = 진짜 ChatGPT Search 답변에 가까움
# 측정 약속과 실체 정합을 위해 운영 환경에서는 true 필수(부팅/배포 preflight 강제).
OPENAI_CHATGPT_USE_WEB_SEARCH=true
