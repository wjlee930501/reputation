# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
# Re:putation вҖ” Public Site (Next.js, Cloud Run)
#   - Multi-stage: л№Ңл“ң лҸ„кө¬лҠ” builderм—җл§Ң, лҹ°нғҖмһ„мқҖ standalone лІҲл“Өл§Ң.
#   - Base pinned by digest (node:24-alpine) вҖ” мһ¬нҳ„ к°ҖлҠҘн•ң л№Ңл“ң.
#   - л№„лЈЁнҠё мӮ¬мҡ©мһҗ мӢӨн–ү. Cloud Runмқҙ PORT(кё°ліё 8080)лҘј мЈјмһ…н•ңлӢӨ.
#
# NEXT_PUBLIC_* лҠ” л№Ңл“ң мӢңм җм—җ нҒҙлқјмқҙм–ёнҠё лІҲл“Өм—җ мқёлқјмқёлҗҳлҜҖлЎң build-argлЎң м „лӢ¬:
#   docker build \
#     --build-arg NEXT_PUBLIC_API_URL=https://<domain>/api/v1/public \
#     --build-arg NEXT_PUBLIC_SITE_URL=https://<domain> \
#     --build-arg NEXT_PUBLIC_BACKEND_URL=https://<domain> \
#     -t site -f site/Dockerfile site
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

# в”Җв”Җ Builder stage в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
FROM node:24-alpine@sha256:2bdb65ed1dab192432bc31c95f94155ca5ad7fc1392fb7eb7526ab682fa5bf14 AS builder
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_BACKEND_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL \
    NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL \
    NEXT_TELEMETRY_DISABLED=1

COPY . .
RUN npm run build

# в”Җв”Җ Runtime stage в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
FROM node:24-alpine@sha256:2bdb65ed1dab192432bc31c95f94155ca5ad7fc1392fb7eb7526ab682fa5bf14 AS runtime
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=8080

# standalone лІҲл“Ө = server.js + н•„мҡ”н•ң node_modulesл§Ң. static/publicмқҖ лі„лҸ„ ліөмӮ¬.
COPY --from=builder --chown=node:node /app/.next/standalone ./
COPY --from=builder --chown=node:node /app/.next/static ./.next/static
COPY --from=builder --chown=node:node /app/public ./public

USER node
EXPOSE 8080

# Cloud RunмқҖ мһҗмІҙ startup/liveness probeлҘј м“ҙлӢӨ вҖ” мқҙ HEALTHCHECKлҠ” лЎңм»¬ docker мҡ©.
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD wget -q --spider "http://127.0.0.1:${PORT}/" || exit 1

CMD ["node", "server.js"]
