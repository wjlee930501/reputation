# ═══════════════════════════════════════════════════════════════════
# Re:putation — Terraform 변수 값
#
# cp terraform.tfvars.example terraform.tfvars
# 실제 값으로 채운 후 terraform apply 실행.
# ═══════════════════════════════════════════════════════════════════

project_id          = "reputation-prod"
region              = "us-central1"
zone                = "us-central1-a"

# ── Domain ─────────────────────────────────────────────────────────
domain              = "reputation.co.kr"
admin_subdomain     = "admin.reputation.co.kr"
dns_zone_name       = ""  # Cloud DNS managed zone (선택)

# ── Database ───────────────────────────────────────────────────────
db_instance_tier = "db-custom-1-3840"
# Create the Cloud SQL app user and DB_PASSWORD Secret Manager version out-of-band
# so the database password never enters Terraform state.

# ── Secrets ────────────────────────────────────────────────────────
# Terraform creates Secret Manager containers only. Add secret versions out-of-band
# before deploying Cloud Run, for example:
# gcloud secrets versions add ADMIN_SECRET_KEY --data-file=-

# ── Site ───────────────────────────────────────────────────────────
site_revalidate_url    = "https://reputation.co.kr/api/revalidate"
