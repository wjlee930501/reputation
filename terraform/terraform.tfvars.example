# ═══════════════════════════════════════════════════════════════════
# Re:putation — Terraform 변수 값
#
# cp terraform.tfvars.example terraform.tfvars
# 실제 값으로 채운 후 terraform apply 실행.
# ═══════════════════════════════════════════════════════════════════

project_id          = "reputation-prod"
region              = "asia-northeast3"
zone                = "asia-northeast3-a"

# ── Domain ─────────────────────────────────────────────────────────
domain              = "reputation.motionlabs.kr"
admin_subdomain     = "admin.reputation.motionlabs.kr"
dns_zone_name       = ""  # Cloud DNS managed zone (선택)
cname_target        = "cname.reputation.motionlabs.kr"
enable_http_redirect = true

# 병원 커스텀 도메인 (병원이 CNAME → CNAME_TARGET 설정을 마친 뒤에 추가할 것 —
# CNAME 없이 apply하면 해당 도메인 cert가 PROVISIONING에 머문다).
# 운영 절차: docs/plans/2026-06-11-custom-domain-runbook.md
# customer_domains = ["jangclinic.co.kr"]

# ── Database ───────────────────────────────────────────────────────
db_edition       = "ENTERPRISE"
db_instance_tier = "db-custom-1-3840"
# Create the Cloud SQL app user and DB_PASSWORD Secret Manager version out-of-band
# so the database password never enters Terraform state.

# ── Secrets ────────────────────────────────────────────────────────
# Terraform creates Secret Manager containers only. Add secret versions out-of-band
# before deploying Cloud Run, for example:
# gcloud secrets versions add ADMIN_SECRET_KEY --data-file=-

# ── Site ───────────────────────────────────────────────────────────
site_revalidate_url    = "https://reputation.motionlabs.kr/api/revalidate"

# ── Container image (INFRA-2) ──────────────────────────────────────
# Prefer an immutable digest so deploys/rollbacks are reproducible. CI/CD
# should set this to the digest it just pushed. Leave empty to fall back to the
# (mutable) :latest tag.
# api_image = "asia-northeast3-docker.pkg.dev/reputation-prod/reputation/reputation@sha256:<digest>"

# ── Backend security env (AUTH-1 / AUTH-5) ─────────────────────────
# CORS allowlist (browser-facing, credentials enabled → HTTPS only, no '*').
# Defaults to https://<domain> and https://<admin_subdomain>; override if needed.
# allowed_origins   = ["https://reputation.motionlabs.kr", "https://admin.reputation.motionlabs.kr"]
# Trusted proxy hops for X-Forwarded-For (rate-limit keying / consent IP).
# Default is the GCP global external LB / GFE source ranges — usually correct
# as-is. NEVER set 0.0.0.0/0 or ::/0: the backend hard-rejects catch-all ranges
# in production (boot crash) because trusting every hop makes the client IP
# spoofable. Override only if a different proxy fronts Cloud Run:
# trusted_proxy_ips = ["130.211.0.0/22", "35.191.0.0/16"]

# ── Redis AUTH/TLS (INFRA-5, opt-in) ───────────────────────────────
# redis_auth_enabled defaults to false: Redis is VPC-private and the plaintext
# redis:// REDIS_URL in cloudrun.tf works out of the box. Enabling AUTH + TLS
# is a COORDINATED change (REDIS_URL must switch to rediss://:<auth>@host:6379/0
# in the same apply or the Celery broker stops connecting) — see redis.tf.
# redis_auth_enabled = true

# ── Sentry (optional) ──────────────────────────────────────────────
# Backend error tracking. Leave unset to disable.
# sentry_dsn = "https://<key>@<org>.ingest.sentry.io/<project>"

# ── Monitoring (optional) ──────────────────────────────────────────
# Email for uptime alerts; channel IDs for the worker/beat ERROR-log alert.
# alert_email           = "ops@motionlabs.kr"
# notification_channels = ["projects/reputation-prod/notificationChannels/123456"]
