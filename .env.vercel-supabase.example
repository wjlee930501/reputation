# Hybrid launch template: Vercel frontends, GCP Cloud Run backend, Supabase Postgres.
# Copy values into Vercel env vars, GCP Secret Manager, or a private local file; do not commit real secrets.

# Shared public URLs
APP_ENV=production
ADMIN_BASE_URL=https://admin.reputation.motionlabs.kr
SITE_BASE_URL=https://reputation.motionlabs.kr
ALLOWED_ORIGINS=https://admin.reputation.motionlabs.kr,https://reputation.motionlabs.kr
TRUSTED_PROXY_IPS=130.211.0.0/22,35.191.0.0/16

# GCP backend runtime: reputation-api, reputation-worker, reputation-beat
DB_CONNECTION_MODE=supabase
GCP_ATTACH_VPC_CONNECTOR=0
GCP_PROJECT_ID=motionlabs-reputation
GCP_REGION=asia-northeast3
GCP_LOCATION=us-central1
PUBLIC_DOMAIN=reputation.motionlabs.kr
ADMIN_DOMAIN=admin.reputation.motionlabs.kr

# Supabase Postgres.
# Use the Supabase session pooler for Cloud Run services and Celery workers.
DATABASE_URL=postgresql+asyncpg://SUPABASE_SESSION_POOLER_URL
SYNC_DATABASE_URL=postgresql+psycopg2://SUPABASE_SESSION_POOLER_URL

# Redis remains required for SlowAPI rate limits and Celery broker/result/RedBeat.
# Use a managed rediss:// endpoint for the lowest fixed-cost launch path, or set GCP_ATTACH_VPC_CONNECTOR=1 for Memorystore.
REDIS_URL=rediss://default:replace-with-real-password@redis.example.com:6379/0

# Backend secrets
ADMIN_SECRET_KEY=replace-with-strong-shared-admin-secret
SITE_BFF_SECRET=replace-with-strong-shared-bff-secret
ANTHROPIC_API_KEY=replace-with-anthropic-key
OPENAI_API_KEY=replace-with-openai-key
GEMINI_API_KEY=replace-with-gemini-key
SLACK_WEBHOOK_URL=SLACK_WEBHOOK_URL_PLACEHOLDER

# GCS/Vertex asset runtime retained for same-day onboarding.
GCP_STORAGE_BUCKET=reputation-images
GCS_REPORTS_BUCKET=reputation-reports
NEXT_PUBLIC_GCP_STORAGE_BUCKET=reputation-images

# Admin Vercel project: reputation-admin, root directory admin
BACKEND_URL=https://api.reputation.motionlabs.kr
NEXT_PUBLIC_BACKEND_URL=https://api.reputation.motionlabs.kr
ADMIN_SESSION_SECRET=replace-with-strong-admin-session-secret

# Site Vercel project: reputation-site, root directory site
NEXT_PUBLIC_API_URL=https://api.reputation.motionlabs.kr/api/v1/public
NEXT_PUBLIC_SITE_URL=https://reputation.motionlabs.kr
SITE_REVALIDATE_SECRET=replace-with-strong-revalidate-secret
