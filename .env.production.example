# ══════════════════════════════════════════════════════════════════
# Re:putation — 프로덕션 환경변수 템플릿 (Cloud Run)
#
# API 키는 Secret Manager에서 주입되므로 여기에 적지 않습니다.
# 대신 .env.production에는 인프라 연결 정보만 넣습니다.
#
# cp .env.production.example .env.production
# ══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
APP_ENV=production
GCP_PROJECT_ID=REPLACE_ME

# ── Database (Cloud SQL) ──────────────────────────────────────────
# DB_PASSWORD는 Secret Manager에서 주입합니다.
DB_USER=reputation
DB_NAME=reputation
CLOUD_SQL_CONNECTION_NAME=project:region:instance

# ── Redis (Memorystore) ───────────────────────────────────────────
# Serverless VPC Access 커넥터로 연결
REDIS_URL=redis://REPLACE_ME:6379/0

# ── Google Cloud ──────────────────────────────────────────────────
GCP_PROJECT_ID=REPLACE_ME
GCP_LOCATION=us-central1
GCP_STORAGE_BUCKET=reputation-images
GCS_REPORTS_BUCKET=reputation-reports

# Cloud Run에서 Application Default Credentials 자동 사용
# GOOGLE_APPLICATION_CREDENTIALS 불필요

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_BASE_URL=https://admin.REPLACE_ME.com
ADMIN_ACTOR_NAME=AE

# ── Site ──────────────────────────────────────────────────────────
SITE_BASE_URL=https://REPLACE_ME.co.kr
ALLOWED_ORIGINS=https://admin.REPLACE_ME.com,https://REPLACE_ME.co.kr

# ── Site Revalidate ───────────────────────────────────────────────
SITE_REVALIDATE_URL=https://REPLACE_ME.co.kr/api/revalidate
SITE_REVALIDATE_SECRET=REPLACE_ME

# ── Sentry ────────────────────────────────────────────────────────
# SENTRY_DSN=https://...

# ── SoV ───────────────────────────────────────────────────────────
SOV_REPEAT_COUNT=10
SOV_REPEAT_COUNT_WEEKLY=5
OPENAI_CHATGPT_USE_WEB_SEARCH=false

# ── Model ─────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
OPENAI_MODEL_QUERY=gpt-4o
OPENAI_MODEL_PARSE=gpt-4o-mini
GEMINI_MODEL=gemini-flash-latest

# ── Lead Retention ────────────────────────────────────────────────
LEAD_RETENTION_DAYS=180
LEAD_CONSENT_VERSION=v1.2026-05
PUBLIC_LEAD_RATE_LIMIT=5/minute;30/hour;100/day

# ── API 키는 Secret Manager에서 주입 ──────────────────────────────
# ANTHROPIC_API_KEY → gcloud secrets versions add ANTHROPIC_API_KEY --data-file=-
# OPENAI_API_KEY    → gcloud secrets versions add OPENAI_API_KEY --data-file=-
# GEMINI_API_KEY    → gcloud secrets versions add GEMINI_API_KEY --data-file=-
# ADMIN_SECRET_KEY  → gcloud secrets versions add ADMIN_SECRET_KEY --data-file=-
# ADMIN_SESSION_SECRET → gcloud secrets versions add ADMIN_SESSION_SECRET --data-file=-
# DB_PASSWORD       → gcloud secrets versions add DB_PASSWORD --data-file=-
# SLACK_WEBHOOK_URL → gcloud secrets versions add SLACK_WEBHOOK_URL --data-file=-

# ── Admin 최고 권한 계정 생성/회전 ────────────────────────────────
# DB 마이그레이션 후 backend 컨테이너/작업 환경에서 실행:
# ADMIN_EMAIL=owner@example.com ADMIN_NAME=Owner ADMIN_PASSWORD='...' python -m app.utils.admin_user create-owner
# ADMIN_PASSWORD는 Secret Manager나 Terraform state에 저장하지 말고 1Password 등에서 일회성으로 주입하세요.
