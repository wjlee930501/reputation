# ══════════════════════════════════════════════════════════════════
# Re:putation — 프로덕션 환경변수 템플릿 (Cloud Run)
#
# API 키는 Secret Manager에서 주입되므로 여기에 적지 않습니다.
# 대신 .env.production에는 인프라 연결 정보만 넣습니다.
#
# cp .env.production.example .env.production
# ══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
APP_ENV=production
GCP_PROJECT_ID=REPLACE_ME

# ── Database (Cloud SQL) ──────────────────────────────────────────
# DB_PASSWORD는 Secret Manager에서 주입합니다.
DB_USER=reputation
DB_NAME=reputation
CLOUD_SQL_CONNECTION_NAME=project:region:instance

# ── Redis (Memorystore) ───────────────────────────────────────────
# Serverless VPC Access 커넥터로 연결
REDIS_URL=redis://REPLACE_ME:6379/0

# ── Google Cloud ──────────────────────────────────────────────────
GCP_PROJECT_ID=REPLACE_ME
GCP_LOCATION=asia-northeast3
GCP_STORAGE_BUCKET=reputation-images
GCS_REPORTS_BUCKET=reputation-reports

# Cloud Run에서 Application Default Credentials 자동 사용
# GOOGLE_APPLICATION_CREDENTIALS 불필요

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_BASE_URL=https://admin.reputation.motionlabs.kr
ADMIN_ACTOR_NAME=AE

# ── Site ──────────────────────────────────────────────────────────
SITE_BASE_URL=https://reputation.motionlabs.kr
CNAME_TARGET=cname.reputation.motionlabs.kr
CUSTOM_DOMAIN_IP_TARGETS=REPLACE_WITH_LB_IP
# CORS — production boot FAILS if this contains '*', http://, or localhost (AUTH-5/INFRA-3).
ALLOWED_ORIGINS=https://admin.reputation.motionlabs.kr,https://reputation.motionlabs.kr

# ── Proxy / client IP (AUTH-1) ────────────────────────────────────
# Real LB/proxy CIDR ranges fronting Cloud Run. Backend parses X-Forwarded-For
# right-to-left and returns the first entry NOT in these ranges as the client IP.
# MUST NOT be 0.0.0.0/0 (would make the client IP spoofable — boot FAILS on it).
# Default below is the GCP global external LB / GFE range; verify for your setup.
# Production boot also FAILS if this is localhost-only.
TRUSTED_PROXY_IPS=130.211.0.0/22,35.191.0.0/16

# ── Site Revalidate ───────────────────────────────────────────────
SITE_REVALIDATE_URL=https://reputation.motionlabs.kr/api/revalidate
SITE_REVALIDATE_SECRET=REPLACE_ME

# ── Site BFF visitor IP (CDX-M1) ──────────────────────────────────
# site의 /api/leads BFF와 공유하는 secret. 설정 시 BFF가 X-BFF-Auth +
# X-Visitor-IP로 실제 방문자 IP를 전달하고 backend가 rate-limit key/consent_ip에
# 채택한다. site Cloud Run 서비스(terraform이 Secret Manager에서 마운트)와
# 동일 값 필요 — 전체 GCP 구성에서는 같은 secret을 양쪽이 읽으므로 자동 일치.
SITE_BFF_SECRET=REPLACE_ME

# ── Sentry ────────────────────────────────────────────────────────
# SENTRY_DSN=https://...

# ── SoV ───────────────────────────────────────────────────────────
SOV_REPEAT_COUNT=10
SOV_REPEAT_COUNT_WEEKLY=5
OPENAI_CHATGPT_USE_WEB_SEARCH=false

# ── Model ─────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
OPENAI_MODEL_QUERY=gpt-4o
OPENAI_MODEL_PARSE=gpt-4o-mini
GEMINI_MODEL=gemini-flash-latest

# ── Lead Retention ────────────────────────────────────────────────
LEAD_RETENTION_DAYS=180
LEAD_CONSENT_VERSION=v1.2026-05
PUBLIC_LEAD_RATE_LIMIT=5/minute;30/hour;100/day
# Public 콘텐츠 허브 읽기 API rate-limit (AUTH-2)
PUBLIC_SITE_RATE_LIMIT=300/minute;6000/hour

# ── Observability (OBS-1) ─────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true

# ── Slack webhook SSRF guard (EXT-1/V-013) ────────────────────────
SLACK_WEBHOOK_ALLOWED_HOSTS=hooks.slack.com

# ── API 키는 Secret Manager에서 주입 ──────────────────────────────
# ANTHROPIC_API_KEY → gcloud secrets versions add ANTHROPIC_API_KEY --data-file=-
# OPENAI_API_KEY    → gcloud secrets versions add OPENAI_API_KEY --data-file=-
# GEMINI_API_KEY    → gcloud secrets versions add GEMINI_API_KEY --data-file=-
# ADMIN_SECRET_KEY  → gcloud secrets versions add ADMIN_SECRET_KEY --data-file=-
# ADMIN_SESSION_SECRET → gcloud secrets versions add ADMIN_SESSION_SECRET --data-file=-
# DB_PASSWORD       → gcloud secrets versions add DB_PASSWORD --data-file=-
# SLACK_WEBHOOK_URL → gcloud secrets versions add SLACK_WEBHOOK_URL --data-file=-

# ── Admin 최고 권한 계정 생성/회전 ────────────────────────────────
# DB 마이그레이션 후 backend 컨테이너/작업 환경에서 실행:
# ADMIN_EMAIL=owner@example.com ADMIN_NAME=Owner ADMIN_PASSWORD='...' python -m app.utils.admin_user create-owner
# ADMIN_PASSWORD는 Secret Manager나 Terraform state에 저장하지 말고 1Password 등에서 일회성으로 주입하세요.
